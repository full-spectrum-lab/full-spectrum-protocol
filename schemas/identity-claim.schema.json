{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/full-spectrum-lab/full-spectrum-protocol/schemas/identity-claim.schema.json",
  "title": "IdentityClaim",
  "description": "A Full Spectrum Protocol identity declaration for a human, AI agent, organization, platform, guardian node, state institution, or composite subject.",
  "type": "object",
  "required": [
    "subject_id",
    "subject_type",
    "display_name",
    "issuer",
    "issued_at",
    "responsibility_owner",
    "audit_required"
  ],
  "properties": {
    "subject_id": {
      "type": "string",
      "description": "Stable identifier for the subject within the issuing context."
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "human",
        "ai_agent",
        "organization",
        "platform",
        "guardian_node",
        "state_institution",
        "composite_subject",
        "other"
      ]
    },
    "display_name": {
      "type": "string"
    },
    "issuer": {
      "type": "string",
      "description": "The entity or system that issues this identity claim."
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "jurisdiction": {
      "type": "string",
      "description": "Applicable legal, organizational, or operational jurisdiction if relevant."
    },
    "responsibility_owner": {
      "type": "string",
      "description": "The human, organization, or accountable entity responsible for this subject."
    },
    "trust_level": {
      "type": "string",
      "enum": [
        "unknown",
        "self_claimed",
        "issuer_verified",
        "guardian_verified",
        "institution_verified"
      ],
      "default": "self_claimed"
    },
    "guardian_verified": {
      "type": "boolean",
      "default": false
    },
    "audit_required": {
      "type": "boolean",
      "description": "Whether interactions from this subject require audit tracing."
    },
    "related_documents": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

