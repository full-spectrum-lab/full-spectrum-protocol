{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/full-spectrum-lab/full-spectrum-protocol/schemas/governance-event.schema.json",
  "title": "GovernanceEvent",
  "description": "Minimal governance record for an AI-related action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "actor",
    "action",
    "context"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique governance event identifier."
    },
    "event_type": {
      "type": "string",
      "enum": [
        "ai_action",
        "tool_call",
        "recommendation",
        "commitment",
        "refusal",
        "escalation",
        "review"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "human",
            "ai_agent",
            "system",
            "organization",
            "network"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "description"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "domain",
        "data_mode"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "data_mode": {
          "type": "string",
          "enum": [
            "synthetic",
            "desensitized",
            "private_internal",
            "public"
          ]
        }
      }
    },
    "declared_capability": {
      "type": "object",
      "additionalProperties": true
    },
    "declared_boundary": {
      "type": "object",
      "additionalProperties": true
    },
    "risk_hint": {
      "type": "object",
      "additionalProperties": true
    },
    "review_requirement": {
      "type": "string",
      "enum": [
        "none",
        "recommended",
        "human_review_required",
        "organizational_review_required",
        "external_review_required"
      ]
    },
    "source_reference": {
      "type": "object",
      "additionalProperties": true
    },
    "subject_ref": { "type": "object", "additionalProperties": true },
    "relationships": {
      "$ref": "#/$defs/relationships"
    }
  },
  "$defs": {
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relation_type", "target_type", "target_id"],
        "properties": {
          "relation_type": { "type": "string", "minLength": 1 },
          "target_type": { "type": "string", "minLength": 1 },
          "target_id": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

